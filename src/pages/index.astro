---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — My Shifts" active="home">
  <div id="app-content">
    <div class="card">
      <h1>Welcome, <span id="user-name">...</span></h1>
      <p style="color:var(--color-muted);margin:0;">Your role: <span id="user-role" class="badge badge-staff"></span></p>
    </div>

    <div class="card">
      <h2>📅 My Upcoming Shifts</h2>
      <div id="shifts-list"><p class="empty">Loading...</p></div>
    </div>

    <div class="grid-2">
      <a href="/AndShawarma/schedule" class="tile">
        <div class="tile-icon">📅</div>
        <div class="tile-title">Full Schedule</div>
        <div class="tile-sub">View all shifts</div>
      </a>
      <a href="/AndShawarma/shift-swap" class="tile">
        <div class="tile-icon">🔄</div>
        <div class="tile-title">Shift Swap</div>
        <div class="tile-sub">Request a swap</div>
      </a>
      <a href="/AndShawarma/time-off" class="tile">
        <div class="tile-icon">🏖️</div>
        <div class="tile-title">Time Off</div>
        <div class="tile-sub">Request / view</div>
      </a>
      <a href="/AndShawarma/admin" class="tile" id="admin-tile" style="display:none;">
        <div class="tile-icon">⚙️</div>
        <div class="tile-title">Manage</div>
        <div class="tile-sub">Admin tools</div>
      </a>
    </div>

    <div class="card">
      <h2>👥 Team Roster</h2>
      <p style="color:var(--color-muted);font-size:0.875rem;">Everyone on the &amp;Shawarma crew and how to reach them.</p>
      <div class="roster-grid" id="roster-grid"><p class="empty">Loading...</p></div>
    </div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();
      await s.ensurePendingLoaded();
      const today = s.todayISO();

      document.getElementById('user-name').textContent = t.display_name;
      const roleEl = document.getElementById('user-role');
      roleEl.textContent = t.role;
      roleEl.className = 'badge badge-' + t.role;
      if (t.role === 'admin' || t.role === 'manager') {
        document.getElementById('admin-tile').style.display = 'block';
      }

      // My upcoming shifts
      const myShifts = s.getShiftsForUser(data, t.user_id).filter(function(x) { return x.date >= today; }).slice(0, 5);
      const list = document.getElementById('shifts-list');
      if (myShifts.length === 0) {
        list.innerHTML = '<p class="empty">No upcoming shifts scheduled.</p>';
      } else {
        list.innerHTML = myShifts.map(function(sh) {
          return '<div class="list-item"><div><div class="who">' + s.formatDate(sh.date, {short: true}) + '</div><div class="meta">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + '</div></div></div>';
        }).join('');
      }

      // Team roster — info only (name, role, phone, email), no shift times
      const sorted = data.users.slice().sort(function(a, b) {
        if (a.role === 'admin' && b.role !== 'admin') return -1;
        if (b.role === 'admin' && a.role !== 'admin') return 1;
        if (a.role === 'manager' && b.role !== 'manager') return -1;
        if (b.role === 'manager' && a.role !== 'manager') return 1;
        return a.display_name.localeCompare(b.display_name);
      });
      document.getElementById('roster-grid').innerHTML = sorted.map(function(u) {
        const roleClass = u.role === 'admin' ? 'role-admin' : u.role === 'manager' ? 'role-manager' : 'role-staff';
        return '<div class="roster-card">' +
          '<div class="roster-card-head">' +
            '<div class="roster-card-name">' + u.display_name + '</div>' +
            '<span class="roster-card-role ' + roleClass + '">' + u.role + '</span>' +
          '</div>' +
          '<div class="roster-card-contact">' +
            '<a href="tel:' + u.phone + '">📞 ' + u.phone + '</a>' +
            '<a href="mailto:' + u.email + '">✉️ ' + u.email + '</a>' +
          '</div>' +
        '</div>';
      }).join('');

      // Demo accounts list (tap to fill login form)
      const demoCreds = [
        { username: 'ray',    password: 'ray2026admin', name: 'Ray Ally',     role: 'admin' },
        { username: 'azmeer', password: 'admin',        name: 'Azmeer',       role: 'admin' },
        { username: 'badar',  password: 'admin',        name: 'Badar Khokar', role: 'admin' },
        { username: 'jorge',  password: 'staff2026',    name: 'Jorge',        role: 'staff' },
        { username: 'jeremy', password: 'staff2026',    name: 'Jeremy',       role: 'staff' },
        { username: 'adnan',  password: 'staff2026',    name: 'Adnan',        role: 'staff' },
        { username: 'david',  password: 'staff2026',    name: 'David',        role: 'staff' },
        { username: 'albero', password: 'staff2026',    name: 'Albero',       role: 'staff' },
        { username: 'john',   password: 'staff2026',    name: 'John',         role: 'staff' },
        { username: 'sanaa',  password: 'staff2026',    name: 'Sanaa',        role: 'staff' },
        { username: 'bhanu',  password: 'staff2026',    name: 'Bhanu',        role: 'staff' },
      ];
      document.getElementById('demo-list').innerHTML = demoCreds.map(function(d) {
        return '<div class="demo-row" data-user="' + d.username + '" data-pass="' + d.password + '">' +
          '<span class="badge badge-' + d.role + '">' + d.role + '</span>' +
          '<span class="demo-name">' + d.name + '</span>' +
          '<code class="demo-cred">' + d.username + ' / ' + d.password + '</code>' +
        '</div>';
      }).join('');
      document.querySelectorAll('.demo-row').forEach(function(r) {
        r.addEventListener('click', function() {
          // Logout and prefill login
          s.clearToken();
          window.location.href = s.baseUrl('/login') + '?u=' + encodeURIComponent(r.getAttribute('data-user')) + '&p=' + encodeURIComponent(r.getAttribute('data-pass'));
        });
      });
    })();
  </script>
</AppLayout>
