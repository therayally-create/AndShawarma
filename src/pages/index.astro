---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — My Shifts" active="home">
  <div id="app-content">
    <div class="card">
      <h1>Welcome, <span id="user-name">...</span></h1>
      <p style="color:var(--color-muted);margin:0;">Your role: <span id="user-role" class="badge badge-staff"></span></p>
    </div>

    <div class="card">
      <h2>📅 My Upcoming Shifts</h2>
      <div id="shifts-list"><p class="empty">Loading...</p></div>
    </div>

    <div class="grid-2">
      <a href="/AndShawarma/schedule" class="tile">
        <div class="tile-icon">📅</div>
        <div class="tile-title">Full Schedule</div>
        <div class="tile-sub">View all shifts</div>
      </a>
      <a href="/AndShawarma/shift-swap" class="tile">
        <div class="tile-icon">🔄</div>
        <div class="tile-title">Shift Swap</div>
        <div class="tile-sub">Request a swap</div>
      </a>
      <a href="/AndShawarma/time-off" class="tile">
        <div class="tile-icon">🏖️</div>
        <div class="tile-title">Time Off</div>
        <div class="tile-sub">Request / view</div>
      </a>
      <a href="/AndShawarma/admin" class="tile" id="admin-tile" style="display:none;">
        <div class="tile-icon">⚙️</div>
        <div class="tile-title">Manage</div>
        <div class="tile-sub">Admin tools</div>
      </a>
    </div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      document.getElementById('user-name').textContent = t.display_name;
      const roleEl = document.getElementById('user-role');
      roleEl.textContent = t.role;
      roleEl.className = 'badge badge-' + t.role;
      if (t.role === 'admin' || t.role === 'manager') {
        document.getElementById('admin-tile').style.display = 'block';
      }
      const data = await s.loadData();
      const today = s.todayISO();
      const myShifts = s.getShiftsForUser(data, t.user_id).filter(function(x) { return x.date >= today; }).slice(0, 5);
      const list = document.getElementById('shifts-list');
      if (myShifts.length === 0) {
        list.innerHTML = '<p class="empty">No upcoming shifts scheduled.</p>';
      } else {
        list.innerHTML = myShifts.map(function(sh) {
          return '<div class="list-item"><div><div class="who">' + s.formatDate(sh.date, {short: true}) + '</div><div class="meta">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + ' · ' + sh.role + '</div></div><span class="badge badge-' + sh.role.toLowerCase() + '">' + sh.role + '</span></div>';
        }).join('');
      }
    })();
  </script>
</AppLayout>
