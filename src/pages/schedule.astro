---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Schedule" active="schedule">
  <div class="calendar-nav">
    <button class="btn-secondary" id="prev-period">← Prev</button>
    <h2 id="period-label">Loading...</h2>
    <button class="btn-secondary" id="next-period">Next →</button>
    <div class="view-toggle" id="view-toggle">
      <button data-view="day">Day</button>
      <button data-view="month" class="active">Month</button>
    </div>
  </div>

  <div id="view-container">
    <p class="empty">Loading...</p>
  </div>

  <!-- Day popup modal -->
  <div class="modal-backdrop" id="day-modal">
    <div class="modal">
      <div class="modal-header">
        <h2 id="modal-title">Day</h2>
        <button class="modal-close" id="modal-close">×</button>
      </div>
      <div class="modal-body">
        <div id="modal-shifts"></div>
        <div id="modal-actions"></div>
      </div>
    </div>
  </div>
</AppLayout>

  <script is:inline src="/AndShawarma/app.js"></script>
  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();
      const today = s.todayISO();
      const isAdmin = (t.role === 'admin' || t.role === 'manager');
      // canEdit = instant save (admin/manager only)
      // canRequest = can submit changes (everyone, but goes to approval queue)
      const canEdit = isAdmin;
      const canRequest = true;

      let view = 'month';
      let viewYear, viewMonth, viewDay;
      const td = new Date(today + 'T00:00:00');
      viewYear = td.getFullYear();
      viewMonth = td.getMonth() + 1;
      viewDay = parseInt(today.slice(8, 10), 10);

      // Pending shift changes that touch THIS user's shifts (color them)
      function myPendingShifts() {
        return s.getPending().filter(function(p) {
          if (p.kind !== 'shift_change') return false;
          if (p.requester_id !== t.user_id) return false;
          if (p.action === 'delete' && p.before) return p.before.user_id === t.user_id;
          if (p.after) return p.after.user_id === t.user_id;
          return false;
        });
      }
      function shiftIsPending(shiftId) {
        return myPendingShifts().some(function(p) {
          return p.shift_id === shiftId && p.status === 'pending';
        });
      }

      function render() {
        const container = document.getElementById('view-container');
        const label = document.getElementById('period-label');

        if (view === 'day') {
          const iso = viewYear + '-' + String(viewMonth).padStart(2,'0') + '-' + String(viewDay).padStart(2,'0');
          label.textContent = s.formatDate(iso);
          const shifts = s.getShiftsForDate(data, iso);
          const addBtn = canEdit
            ? '<button class="btn-primary" id="day-add">+ Add shift</button>'
            : '<button class="btn-primary" id="day-add" style="background:var(--color-warning);">+ Request shift</button>';
          if (shifts.length === 0) {
            container.innerHTML = '<div class="day-view"><p class="empty" style="text-align:center;padding:2rem;">No shifts on this day.</p>' + addBtn + '</div>';
          } else {
            container.innerHTML = '<div class="day-view">' +
              shifts.map(function(sh) {
                const pending = shiftIsPending(sh.id);
                const editLabel = canEdit ? 'Edit' : 'Request change';
                const editBtn = '<button class="btn-secondary" data-edit="' + sh.id + '">' + editLabel + '</button>';
                return '<div class="day-shift ' + sh.role.toLowerCase() + (pending ? ' pending' : '') + '">' +
                  '<div class="day-shift-main">' +
                    '<div class="day-shift-name">' + s.getUserName(data, sh.user_id) + (pending ? ' <span class="badge badge-pending" style="font-size:0.625rem;">pending</span>' : '') + '</div>' +
                    '<div class="day-shift-time">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + '</div>' +
                    '<div class="day-shift-role">' + sh.role + (sh.notes ? ' · ' + sh.notes : '') + '</div>' +
                  '</div>' +
                  '<div class="day-shift-actions">' + editBtn + '</div>' +
                '</div>';
              }).join('') + addBtn + '</div>';
          }
          if (canRequest) {
            const addBtn2 = container.querySelector('#day-add');
            if (addBtn2) addBtn2.addEventListener('click', function() { openShiftEditor(iso, null); });
            container.querySelectorAll('[data-edit]').forEach(function(b) {
              b.addEventListener('click', function() { openShiftEditor(iso, b.getAttribute('data-edit')); });
            });
          }
          return;
        }

        if (view === 'month') {
          label.textContent = s.formatDate(viewYear + '-' + String(viewMonth).padStart(2,'0') + '-01', { monthYear: true });
          const range = s.getMonthRange(viewYear, viewMonth);
          const blocks = s.getTimeOffBlocks(data);
          const firstDate = new Date(viewYear, viewMonth - 1, 1);
          const firstDow = firstDate.getDay();
          const cells = [];
          for (let i = 0; i < firstDow; i++) {
            const d = new Date(firstDate);
            d.setDate(d.getDate() - (firstDow - i));
            cells.push({ iso: d.toISOString().slice(0,10), other: true });
          }
          for (let i = 0; i < range.days.length; i++) cells.push({ iso: range.days[i], other: false });
          while (cells.length % 7 !== 0) {
            const last = new Date(cells[cells.length-1].iso + 'T00:00:00');
            last.setDate(last.getDate() + 1);
            cells.push({ iso: last.toISOString().slice(0,10), other: true });
          }
          const head = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(function(d) { return '<div class="calendar-head">' + d + '</div>'; }).join('');
          const body = cells.map(function(c) {
            const dayShifts = s.getShiftsForDate(data, c.iso);
            const dayBlocks = blocks.filter(function(b) { return b.date === c.iso; });
            // Find time-off block for THIS cell that's a continuation
            // (only show the bar starting at the first day of a run, but
            // mark the start day and continuation days differently)
            const prev = new Date(c.iso + 'T00:00:00');
            prev.setDate(prev.getDate() - 1);
            const prevISO = prev.toISOString().slice(0, 10);
            const blockStartsHere = dayBlocks.length > 0 && !s.isBlocked(blocks, prevISO, dayBlocks[0].user_id);
            const blockHTML = dayBlocks.length > 0
              ? (blockStartsHere
                  ? '<div class="time-off-bar" title="' + dayBlocks[0].reason + '">🏖️ ' + s.getUserName(data, dayBlocks[0].user_id) + ' — ' + (dayBlocks[0].reason || 'on leave') + '</div>'
                  : '<div class="time-off-bar time-off-cont" title="(cont.) ' + dayBlocks[0].reason + '">🏖️ cont.</div>')
              : '';
            const lines = dayShifts.slice(0, 3).map(function(sh) {
              const blocked = s.isBlocked(blocks, c.iso, sh.user_id);
              const firstName = s.getUserName(data, sh.user_id).split(' ')[0];
              return '<div class="shift-line ' + sh.role.toLowerCase() + (blocked ? ' on-leave' : '') + '"><strong>' + firstName + '</strong> ' + s.formatTime12(sh.start) + '–' + s.formatTime12(sh.end) + (blocked ? ' 🏖️' : '') + '</div>';
            }).join('');
            const more = dayShifts.length > 3 ? '<div class="shift-line">+' + (dayShifts.length - 3) + ' more</div>' : '';
            const isToday = c.iso === today;
            return '<div class="calendar-day' + (c.other ? ' other-month' : '') + (isToday ? ' today' : '') + (dayBlocks.length > 0 ? ' has-timeoff' : '') + '" data-iso="' + c.iso + '">' +
              '<span class="day-num">' + parseInt(c.iso.slice(8,10), 10) + '</span>' +
              blockHTML + lines + more +
            '</div>';
          }).join('');
          container.innerHTML = '<div class="calendar-grid">' + head + body + '</div>';
          container.querySelectorAll('.calendar-day').forEach(function(el) {
            el.addEventListener('click', function() { openDay(el.getAttribute('data-iso')); });
          });
          return;
        }
      }

      function updateToggle() {
        document.querySelectorAll('#view-toggle button').forEach(function(b) {
          b.classList.toggle('active', b.getAttribute('data-view') === view);
        });
      }

      function openDay(iso) {
        const dayShifts = s.getShiftsForDate(data, iso);
        document.getElementById('modal-title').textContent = s.formatDate(iso);
        const shiftsHTML = dayShifts.length === 0
          ? '<p class="empty">No shifts scheduled.</p>'
          : dayShifts.map(function(sh) {
              const pending = shiftIsPending(sh.id);
              const editLabel = canEdit ? 'Edit' : 'Request change';
              const editBtn = '<button class="btn-secondary" data-edit="' + sh.id + '">' + editLabel + '</button>';
              return '<div class="day-shift ' + sh.role.toLowerCase() + (pending ? ' pending' : '') + '">' +
                '<div class="day-shift-main">' +
                  '<div class="day-shift-name">' + s.getUserName(data, sh.user_id) + (pending ? ' <span class="badge badge-pending" style="font-size:0.625rem;">pending</span>' : '') + '</div>' +
                  '<div class="day-shift-time">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + '</div>' +
                  '<div class="day-shift-role">' + sh.role + (sh.notes ? ' · ' + sh.notes : '') + '</div>' +
                '</div>' +
                '<div class="day-shift-actions">' + editBtn + '</div>' +
              '</div>';
            }).join('');
        document.getElementById('modal-shifts').innerHTML = shiftsHTML;
        const addBtn = canEdit
          ? '<button class="btn-primary" id="add-shift-btn" style="margin-top:0.75rem;">+ Add shift</button>'
          : '<button class="btn-primary" id="add-shift-btn" style="margin-top:0.75rem;background:var(--color-warning);">+ Request shift</button>';
        document.getElementById('modal-actions').innerHTML = addBtn;
        if (canRequest) {
          document.getElementById('add-shift-btn').addEventListener('click', function() { openShiftEditor(iso, null); });
          document.querySelectorAll('[data-edit]').forEach(function(b) {
            b.addEventListener('click', function() { openShiftEditor(iso, b.getAttribute('data-edit')); });
          });
        }
        document.getElementById('day-modal').classList.add('show');
      }

      function openShiftEditor(iso, shiftId) {
        const sh = shiftId ? data.shifts.find(function(x) { return x.id === shiftId; }) : null;
        const isNew = !sh;
        const userOptions = data.users.map(function(u) {
          const sel = sh && sh.user_id === u.id ? ' selected' : '';
          return '<option value="' + u.id + '"' + sel + '>' + u.display_name + ' (' + u.role + ')</option>';
        }).join('');
        const fohSel = sh && sh.role === 'FOH' ? ' selected' : '';
        const bohSel = sh && sh.role === 'BOH' ? ' selected' : '';
        const editorHTML =
          '<div class="modal-backdrop show" id="editor-modal" style="z-index:300;">' +
            '<div class="modal">' +
              '<div class="modal-header">' +
                '<h2>' + (isNew ? 'New shift' : 'Edit shift') + '</h2>' +
                '<button class="modal-close" id="editor-close">×</button>' +
              '</div>' +
              '<div class="modal-body">' +
                '<div class="field"><label>Staff</label><select id="ed-user" class="input">' + userOptions + '</select></div>' +
                '<div class="field"><label>Date</label><input type="date" id="ed-date" class="input" value="' + (sh ? sh.date : iso) + '" /></div>' +
                '<div class="field"><label>Start time</label><input type="time" id="ed-start" class="input" value="' + (sh ? sh.start : '11:00') + '" /></div>' +
                '<div class="field"><label>End time</label><input type="time" id="ed-end" class="input" value="' + (sh ? sh.end : '19:00') + '" /></div>' +
                '<div class="field"><label>Role</label><select id="ed-role" class="input"><option value="FOH"' + fohSel + '>FOH (front of house)</option><option value="BOH"' + bohSel + '>BOH (back of house)</option></select></div>' +
                '<div class="field"><label>Notes</label><input type="text" id="ed-notes" class="input" value="' + (sh && sh.notes ? sh.notes : '') + '" placeholder="Optional" /></div>' +
              '</div>' +
              '<div class="modal-footer">' +
                (isNew ? '' : '<button class="btn-secondary" id="ed-delete">Delete</button>') +
                '<button class="btn-primary" id="ed-save">Save</button>' +
              '</div>' +
            '</div>' +
          '</div>';
        const wrap = document.createElement('div');
        wrap.innerHTML = editorHTML;
        document.body.appendChild(wrap);
        function closeEditor() { document.body.removeChild(wrap); }
        wrap.querySelector('#editor-close').addEventListener('click', closeEditor);
        wrap.querySelector('#ed-save').addEventListener('click', function() {
          const payload = {
            kind: 'shift_change', shift_id: sh ? sh.id : null,
            date: wrap.querySelector('#ed-date').value,
            user_id: wrap.querySelector('#ed-user').value,
            start: wrap.querySelector('#ed-start').value,
            end: wrap.querySelector('#ed-end').value,
            role: wrap.querySelector('#ed-role').value,
            notes: wrap.querySelector('#ed-notes').value,
          };
          s.addPending({
            kind: 'shift_change', requester_id: t.user_id, requester_name: t.display_name,
            action: isNew ? 'create' : 'update', before: sh || null, after: payload,
          });
          closeEditor();
          document.getElementById('day-modal').classList.remove('show');
          s.toast('Change requested — admin notified');
        });
        if (!isNew) {
          wrap.querySelector('#ed-delete').addEventListener('click', function() {
            s.addPending({
              kind: 'shift_change', requester_id: t.user_id, requester_name: t.display_name,
              action: 'delete', before: sh, after: null,
            });
            closeEditor();
            document.getElementById('day-modal').classList.remove('show');
            s.toast('Delete requested — admin notified');
          });
        }
      }

      // View toggle
      document.querySelectorAll('#view-toggle button').forEach(function(b) {
        b.addEventListener('click', function() {
          view = b.getAttribute('data-view');
          updateToggle();
          render();
        });
      });

      // Prev/Next
      document.getElementById('prev-period').addEventListener('click', function() {
        if (view === 'day') {
          const d = new Date(viewYear, viewMonth - 1, viewDay);
          d.setDate(d.getDate() - 1);
          viewYear = d.getFullYear(); viewMonth = d.getMonth() + 1; viewDay = d.getDate();
        } else {
          viewMonth--; if (viewMonth < 1) { viewMonth = 12; viewYear--; }
        }
        render();
      });
      document.getElementById('next-period').addEventListener('click', function() {
        if (view === 'day') {
          const d = new Date(viewYear, viewMonth - 1, viewDay);
          d.setDate(d.getDate() + 1);
          viewYear = d.getFullYear(); viewMonth = d.getMonth() + 1; viewDay = d.getDate();
        } else {
          viewMonth++; if (viewMonth > 12) { viewMonth = 1; viewYear++; }
        }
        render();
      });
      document.getElementById('modal-close').addEventListener('click', function() {
        document.getElementById('day-modal').classList.remove('show');
      });
      document.getElementById('day-modal').addEventListener('click', function(e) {
        if (e.target.id === 'day-modal') document.getElementById('day-modal').classList.remove('show');
      });

      render();
    })();
  </script>
</AppLayout>
