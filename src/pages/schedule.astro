---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Schedule" active="schedule">
  <div class="week-nav">
    <button class="btn-secondary" id="prev-week">← Prev</button>
    <h2 id="week-label">Loading...</h2>
    <button class="btn-secondary" id="next-week">Next →</button>
  </div>

  <div class="schedule-grid" id="schedule-grid">
    <p class="empty">Loading...</p>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();
      let weekStart = s.getMondayOf(s.todayISO());

      function render() {
        const range = s.getWeekRange(weekStart);
        const startD = new Date(range.start + 'T00:00:00');
        const endD = new Date(range.end + 'T00:00:00');
        document.getElementById('week-label').innerHTML =
          startD.toLocaleDateString('en-US',{month:'short',day:'numeric'}) + ' – ' +
          endD.toLocaleDateString('en-US',{month:'short',day:'numeric'}) +
          '<div class="range">' + startD.getFullYear() + '</div>';
        const grid = document.getElementById('schedule-grid');
        grid.innerHTML = range.days.map(function(date) {
          const header = s.formatDayHeader(date);
          const shifts = s.getShiftsForDate(data, date);
          let shiftsHTML;
          if (shifts.length === 0) {
            shiftsHTML = '<p class="empty" style="padding:0.5rem 0;font-size:0.75rem;">—</p>';
          } else {
            shiftsHTML = shifts.map(function(sh) {
              const mine = sh.user_id === t.user_id;
              return '<div class="shift-chip ' + sh.role.toLowerCase() + (mine ? ' mine' : '') + '">' +
                '<span class="who">' + s.getUserName(data, sh.user_id) + '</span>' +
                '<span class="time">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + '</span>' +
                '</div>';
            }).join('');
          }
          return '<div class="day-col' + (header.isToday ? ' today' : '') + '">' +
            '<div class="day-col-head">' + header.weekday + '<span class="date">' + header.day + '</span></div>' +
            shiftsHTML +
            '</div>';
        }).join('');
      }

      document.getElementById('prev-week').addEventListener('click', function() {
        const d = new Date(weekStart + 'T00:00:00');
        d.setDate(d.getDate() - 7);
        weekStart = d.toISOString().slice(0, 10);
        render();
      });
      document.getElementById('next-week').addEventListener('click', function() {
        const d = new Date(weekStart + 'T00:00:00');
        d.setDate(d.getDate() + 7);
        weekStart = d.toISOString().slice(0, 10);
        render();
      });
      render();
    })();
  </script>
</AppLayout>
