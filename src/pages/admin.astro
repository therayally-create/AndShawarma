---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Manage" active="admin">
  <div class="card" id="approvals-card">
    <h2>⏳ Pending Approvals <span id="pending-count" class="badge badge-pending" style="vertical-align:middle;">0</span></h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">All change requests from staff. Approving writes the change; denying rejects it.</p>
    <div id="approvals-list"><p class="empty">No pending requests.</p></div>
  </div>

  <div class="card">
    <h2>👥 Users</h2>
    <div id="users-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card">
    <h2>📅 Shifts This Month</h2>
    <div id="shifts-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card">
    <h2>🏖️ Time-Off</h2>
    <div id="timeoff-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth(['admin', 'manager']);
      if (!t) return;
      const data = await s.loadData();

      function renderApprovals() {
        const list = document.getElementById('approvals-list');
        const pending = s.getPending().filter(function(p) { return p.status === 'pending'; });
        document.getElementById('pending-count').textContent = pending.length;
        if (pending.length === 0) {
          list.innerHTML = '<p class="empty">No pending requests.</p>';
          return;
        }
        list.innerHTML = pending.map(function(p) {
          let detail = '';
          let actionBtns = '<button class="btn-primary" data-approve="' + p.id + '">Approve</button> <button class="btn-secondary" data-deny="' + p.id + '">Deny</button>';
          if (p.kind === 'time_off') {
            detail = '<div class="who">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + '</div><div class="meta">' + (p.reason || '—') + '</div>';
          } else if (p.kind === 'shift_swap') {
            const shift = data.shifts.find(function(x) { return x.id === p.shift_id; });
            const shiftDate = shift ? s.formatDate(shift.date, {short:true}) + ' · ' + s.formatTime12(shift.start) + '–' + s.formatTime12(shift.end) : '—';
            detail = '<div class="who">Swap → ' + (p.target_user_name || '?') + '</div><div class="meta">' + shiftDate + '</div>';
          } else if (p.kind === 'shift_change') {
            const b = p.before, a = p.after;
            if (p.action === 'create') {
              detail = '<div class="who">+ New shift: ' + s.getUserName(data, a.user_id) + '</div><div class="meta">' + s.formatDate(a.date, {short:true}) + ' · ' + s.formatTime12(a.start) + '–' + s.formatTime12(a.end) + ' · ' + a.role + '</div>';
            } else if (p.action === 'delete') {
              detail = '<div class="who">− Delete shift: ' + s.getUserName(data, b.user_id) + '</div><div class="meta">' + s.formatDate(b.date, {short:true}) + ' · ' + s.formatTime12(b.start) + '–' + s.formatTime12(b.end) + '</div>';
            } else {
              detail = '<div class="who">~ Edit shift: ' + s.getUserName(data, a.user_id) + '</div><div class="meta">' +
                (b.date !== a.date ? '<b>date:</b> ' + s.formatDate(b.date, {short:true}) + ' → ' + s.formatDate(a.date, {short:true}) + '<br/>' : '') +
                (b.start !== a.start || b.end !== a.end ? '<b>time:</b> ' + s.formatTime12(b.start) + '–' + s.formatTime12(b.end) + ' → ' + s.formatTime12(a.start) + '–' + s.formatTime12(a.end) + '<br/>' : '') +
                (b.role !== a.role ? '<b>role:</b> ' + b.role + ' → ' + a.role + '<br/>' : '') +
                (b.user_id !== a.user_id ? '<b>staff:</b> ' + s.getUserName(data, b.user_id) + ' → ' + s.getUserName(data, a.user_id) : '') +
                '</div>';
            }
          }
          return '<div class="list-item" style="flex-direction:column;align-items:stretch;gap:0.5rem;padding:0.75rem 0;">' +
            '<div style="display:flex;justify-content:space-between;align-items:center;">' +
              '<div><span class="badge badge-' + (p.kind === 'shift_change' ? 'foh' : p.kind === 'time_off' ? 'boh' : 'pending') + '">' + p.kind.replace('_',' ') + '</span> <strong>' + (p.requester_name || '?') + '</strong></div>' +
              '<div style="display:flex;gap:0.5rem;align-items:center;">' + actionBtns + '</div>' +
            '</div>' +
            '<div style="padding-left:0.25rem;">' + detail + '</div>' +
          '</div>';
        }).join('');

        list.querySelectorAll('[data-approve]').forEach(function(b) {
          b.addEventListener('click', function() {
            s.resolvePending(b.getAttribute('data-approve'), 'approved');
            s.toast('Approved');
            renderApprovals();
          });
        });
        list.querySelectorAll('[data-deny]').forEach(function(b) {
          b.addEventListener('click', function() {
            s.resolvePending(b.getAttribute('data-deny'), 'denied');
            s.toast('Denied');
            renderApprovals();
          });
        });
      }

      const usersList = document.getElementById('users-list');
      usersList.innerHTML = data.users.map(function(u) {
        const initials = u.display_name.split(' ').map(function(p) { return p[0]; }).join('').slice(0, 2).toUpperCase();
        return '<div class="user-row"><div class="avatar">' + initials + '</div><div class="info"><div class="name">' + u.display_name + '</div><div class="username">@' + u.username + '</div></div><span class="badge badge-' + u.role + '">' + u.role + '</span></div>';
      }).join('');

      const monthStart = new Date(); monthStart.setDate(1);
      const monthEnd = new Date(monthStart.getFullYear(), monthStart.getMonth() + 1, 0);
      const msISO = monthStart.toISOString().slice(0,10);
      const meISO = monthEnd.toISOString().slice(0,10);
      const monthShifts = s.getShiftsInRange(data, msISO, meISO);
      const shiftsList = document.getElementById('shifts-list');
      shiftsList.innerHTML = '<p style="color:var(--color-muted);font-size:0.875rem;margin:0 0 0.5rem;">' + monthShifts.length + ' shifts in ' + s.formatDate(msISO, {monthYear:true}) + '</p>' +
        monthShifts.slice(0, 20).map(function(sh) {
          return '<div class="list-item"><div><div class="who">' + s.formatDate(sh.date, {short:true}) + ' · ' + s.formatTime12(sh.start) + '–' + s.formatTime12(sh.end) + '</div><div class="meta">' + s.getUserName(data, sh.user_id) + '</div></div><span class="badge badge-' + sh.role.toLowerCase() + '">' + sh.role + '</span></div>';
        }).join('') +
        (monthShifts.length > 20 ? '<p style="color:var(--color-muted);font-size:0.75rem;text-align:center;margin:0.5rem 0 0;">+ ' + (monthShifts.length - 20) + ' more (see Schedule page)</p>' : '');

      const toList = document.getElementById('timeoff-list');
      if (data.time_off.length === 0) {
        toList.innerHTML = '<p class="empty">No requests.</p>';
      } else {
        toList.innerHTML = data.time_off.map(function(it) {
          return '<div class="list-item"><div><div class="who">' + s.getUserName(data, it.user_id) + '</div><div class="meta">' + s.formatDate(it.start_date, {short:true}) + ' – ' + s.formatDate(it.end_date, {short:true}) + ' · ' + (it.reason || '—') + '</div></div><span class="badge badge-' + it.status + '">' + it.status + '</span></div>';
        }).join('');
      }

      renderApprovals();
    })();
  </script>
</AppLayout>
