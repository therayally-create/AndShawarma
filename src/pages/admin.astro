---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Manage" active="admin">
  <div class="card" id="approvals-card">
    <h2>⏳ Pending Approvals <span id="pending-count" class="badge badge-pending" style="vertical-align:middle;">0</span></h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">All change requests from staff. Approving writes the change; denying rejects it.</p>
    <div id="approvals-list"><p class="empty">No pending requests.</p></div>
  </div>

  <div class="card">
    <h2>👥 Users</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">Manage who can log in. Disabled users can't sign in but their schedule data is kept.</p>
    <div style="margin-bottom:0.75rem;">
      <button class="btn-primary" id="add-user-btn">+ Add user</button>
    </div>
    <div id="users-list"><p class="empty">Loading...</p></div>
  </div>

  <!-- Add user modal -->
  <div class="modal-backdrop" id="add-user-modal">
    <div class="modal">
      <div class="modal-header">
        <h2>Add new user</h2>
        <button class="modal-close" id="add-user-close">×</button>
      </div>
      <div class="modal-body">
        <div class="field"><label>Full name</label><input type="text" id="au-name" class="input" placeholder="e.g. John Smith" required /></div>
        <div class="field"><label>Username</label><input type="text" id="au-username" class="input" placeholder="e.g. john" required /></div>
        <div class="field"><label>Password</label><input type="text" id="au-password" class="input" placeholder="Initial password" required /></div>
        <div class="field"><label>Role</label>
          <select id="au-role" class="input">
            <option value="staff">Staff</option>
            <option value="manager">Manager</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="field"><label>Phone</label><input type="tel" id="au-phone" class="input" placeholder="+15551234567" /></div>
        <div class="field"><label>Email</label><input type="email" id="au-email" class="input" placeholder="user@example.com" /></div>
      </div>
      <div class="modal-footer">
        <button class="btn-primary" id="au-save">Create user</button>
      </div>
    </div>
  </div>

  <!-- Edit user modal (reset password, edit profile, disable) -->
  <div class="modal-backdrop" id="edit-user-modal">
    <div class="modal">
      <div class="modal-header">
        <h2 id="edit-user-title">Edit user</h2>
        <button class="modal-close" id="edit-user-close">×</button>
      </div>
      <div class="modal-body">
        <div class="field"><label>Full name</label><input type="text" id="eu-name" class="input" /></div>
        <div class="field"><label>Phone</label><input type="tel" id="eu-phone" class="input" /></div>
        <div class="field"><label>Email</label><input type="email" id="eu-email" class="input" /></div>
        <div class="field"><label>Role</label>
          <select id="eu-role" class="input">
            <option value="staff">Staff</option>
            <option value="manager">Manager</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <hr style="border:none;border-top:1px solid var(--color-border);margin:1rem 0;" />
        <div class="field"><label>Reset password</label>
          <div style="display:flex;gap:0.5rem;">
            <input type="text" id="eu-new-password" class="input" placeholder="New password (leave blank to keep)" />
            <button class="btn-secondary" id="eu-generate" type="button">Generate</button>
          </div>
        </div>
        <hr style="border:none;border-top:1px solid var(--color-border);margin:1rem 0;" />
        <div class="field">
          <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
            <input type="checkbox" id="eu-disabled" style="width:1rem;height:1rem;" />
            <span>Disable this account (cannot log in, but data preserved)</span>
          </label>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" id="eu-delete" style="margin-right:auto;color:#991b1b;">Delete user</button>
        <button class="btn-primary" id="eu-save">Save changes</button>
      </div>
    </div>
  </div>

  <div class="card">
    <h2>🏖️ Time-Off</h2>
    <div id="timeoff-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth(['admin', 'manager']);
      if (!t) return;
      const data = await s.loadData();
      await s.ensurePendingLoaded();

      function renderApprovals() {
        const list = document.getElementById('approvals-list');
        const all = s.getPending();
        const pending = all.filter(function(p) { return p.status === 'pending'; });
        document.getElementById('pending-count').textContent = pending.length;
        if (pending.length === 0) {
          list.innerHTML =
            '<p class="empty" style="margin-bottom:0.75rem;">No pending requests. They show up here when staff submit changes.</p>' +
            (isAdmin ? '<button class="btn-secondary" id="seed-demo-btn" type="button">+ Add test request (demo)</button>' : '');
          if (isAdmin) {
            const seedBtn = document.getElementById('seed-demo-btn');
            if (seedBtn) seedBtn.addEventListener('click', function() {
              s.addPending({
                kind: 'time_off',
                requester_id: 'u4', // Jorge
                start_date: '2026-07-20', end_date: '2026-07-22',
                reason: 'Doctor appointment (test request)',
              });
              s.toast('Test request added — refresh the list');
              renderApprovals();
            });
          }
          return;
        }
        list.innerHTML = pending.map(function(p) {
          let detail = '';
          let actionBtns = '<button class="btn-primary" data-approve="' + p.id + '">Approve</button> <button class="btn-secondary" data-deny="' + p.id + '">Deny</button>';
          if (p.kind === 'time_off') {
            detail = '<div class="who">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + '</div><div class="meta">' + (p.reason || '—') + '</div>';
          } else if (p.kind === 'shift_swap') {
            const shift = data.shifts.find(function(x) { return x.id === p.shift_id; });
            const shiftDate = shift ? s.formatDate(shift.date, {short:true}) + ' · ' + s.formatTime12(shift.start) + '–' + s.formatTime12(shift.end) : '—';
            detail = '<div class="who">Swap → ' + (p.target_user_name || '?') + '</div><div class="meta">' + shiftDate + '</div>';
          } else if (p.kind === 'shift_change') {
            const b = p.before, a = p.after;
            if (p.action === 'create') {
              detail = '<div class="who">+ New shift: ' + s.getUserName(data, a.user_id) + '</div><div class="meta">' + s.formatDate(a.date, {short:true}) + ' · ' + s.formatTime12(a.start) + '–' + s.formatTime12(a.end) + ' · ' + a.role + '</div>';
            } else if (p.action === 'delete') {
              detail = '<div class="who">− Delete shift: ' + s.getUserName(data, b.user_id) + '</div><div class="meta">' + s.formatDate(b.date, {short:true}) + ' · ' + s.formatTime12(b.start) + '–' + s.formatTime12(b.end) + '</div>';
            } else {
              detail = '<div class="who">~ Edit shift: ' + s.getUserName(data, a.user_id) + '</div><div class="meta">' +
                (b.date !== a.date ? '<b>date:</b> ' + s.formatDate(b.date, {short:true}) + ' → ' + s.formatDate(a.date, {short:true}) + '<br/>' : '') +
                (b.start !== a.start || b.end !== a.end ? '<b>time:</b> ' + s.formatTime12(b.start) + '–' + s.formatTime12(b.end) + ' → ' + s.formatTime12(a.start) + '–' + s.formatTime12(a.end) + '<br/>' : '') +
                (b.role !== a.role ? '<b>role:</b> ' + b.role + ' → ' + a.role + '<br/>' : '') +
                (b.user_id !== a.user_id ? '<b>staff:</b> ' + s.getUserName(data, b.user_id) + ' → ' + s.getUserName(data, a.user_id) : '') +
                '</div>';
            }
          }
          return '<div class="list-item" style="flex-direction:column;align-items:stretch;gap:0.5rem;padding:0.75rem 0;">' +
            '<div style="display:flex;justify-content:space-between;align-items:center;">' +
              '<div><span class="badge badge-' + (p.kind === 'shift_change' ? 'foh' : p.kind === 'time_off' ? 'boh' : 'pending') + '">' + p.kind.replace('_',' ') + '</span> <strong>' + (p.requester_name || '?') + '</strong></div>' +
              '<div style="display:flex;gap:0.5rem;align-items:center;">' + actionBtns + '</div>' +
            '</div>' +
            '<div style="padding-left:0.25rem;">' + detail + '</div>' +
          '</div>';
        }).join('');

        list.querySelectorAll('[data-approve]').forEach(function(b) {
          b.addEventListener('click', async function() {
            const id = b.getAttribute('data-approve');
            // 1. Update the Sheet (the source of truth)
            await s.updateSheetRow('pending', 'id', id, { status: 'approved' });
            // 2. Update local cache + re-render
            s.resolvePending(id, 'approved');
            s.toast('Approved');
            await s.loadData();
            renderApprovals();
            renderTimeOff();
          });
        });
        list.querySelectorAll('[data-deny]').forEach(function(b) {
          b.addEventListener('click', async function() {
            const id = b.getAttribute('data-deny');
            const reason = prompt('Why are you denying this request? (shown to the staff member)');
            if (reason === null) return;
            await s.updateSheetRow('pending', 'id', id, { status: 'denied', denial_reason: reason || 'No reason given' });
            s.resolvePending(id, 'denied');
            s.toast('Denied');
            await s.loadData();
            renderApprovals();
            renderTimeOff();
          });
        });
      }

      const usersList = document.getElementById('users-list');
      function renderUsers() {
        usersList.innerHTML = data.users.map(function(u) {
          const disabledBadge = u.disabled ? ' <span class="badge badge-denied">disabled</span>' : '';
          return '<div class="user-row">' +
            '<div class="info" style="flex:1;min-width:0;">' +
              '<div class="name">' + u.display_name + disabledBadge + '</div>' +
              '<div class="username">@' + u.username + '</div>' +
            '</div>' +
            '<span class="badge badge-' + u.role + '">' + u.role + '</span>' +
            '<button class="btn-secondary" data-edit-user="' + u.id + '" style="margin-left:0.5rem;">Edit</button>' +
          '</div>';
        }).join('');
        usersList.querySelectorAll('[data-edit-user]').forEach(function(b) {
          b.addEventListener('click', function() { openEditUser(b.getAttribute('data-edit-user')); });
        });
      }
      renderUsers();

      // === User CRUD ===
      // Add user modal
      function openAddUser() {
        document.getElementById('au-name').value = '';
        document.getElementById('au-username').value = '';
        document.getElementById('au-password').value = '';
        document.getElementById('au-role').value = 'staff';
        document.getElementById('au-phone').value = '';
        document.getElementById('au-email').value = '';
        document.getElementById('add-user-modal').classList.add('show');
      }
      document.getElementById('add-user-btn').addEventListener('click', openAddUser);
      document.getElementById('add-user-close').addEventListener('click', function() {
        document.getElementById('add-user-modal').classList.remove('show');
      });
      document.getElementById('au-save').addEventListener('click', async function() {
        const name = document.getElementById('au-name').value.trim();
        const username = document.getElementById('au-username').value.trim();
        const password = document.getElementById('au-password').value;
        const role = document.getElementById('au-role').value;
        const phone = document.getElementById('au-phone').value.trim();
        const email = document.getElementById('au-email').value.trim();
        if (!name || !username || !password) { s.toast('Name, username, password required'); return; }
        if (data.users.find(function(u) { return u.username === username; })) {
          s.toast('Username already exists'); return;
        }
        const id = 'u' + (Date.now().toString(36));
        const hash = await s.sha256(password);
        data.users.push({
          id: id, username: username, password_hash: hash, role: role,
          display_name: name, email: email || username + '@andshawarma.example',
          phone: phone || '+10000000000', disabled: false
        });
        document.getElementById('add-user-modal').classList.remove('show');
        s.toast('User created: ' + username);
        renderUsers();
      });

      // Edit user modal
      let editingUserId = null;
      function openEditUser(uid) {
        const u = data.users.find(function(x) { return x.id === uid; });
        if (!u) return;
        editingUserId = uid;
        document.getElementById('edit-user-title').textContent = 'Edit: ' + u.display_name;
        document.getElementById('eu-name').value = u.display_name;
        document.getElementById('eu-phone').value = u.phone || '';
        document.getElementById('eu-email').value = u.email || '';
        document.getElementById('eu-role').value = u.role;
        document.getElementById('eu-new-password').value = '';
        document.getElementById('eu-disabled').checked = !!u.disabled;
        document.getElementById('edit-user-modal').classList.add('show');
      }
      document.getElementById('edit-user-close').addEventListener('click', function() {
        document.getElementById('edit-user-modal').classList.remove('show');
        editingUserId = null;
      });
      document.getElementById('eu-generate').addEventListener('click', function() {
        const random = Math.random().toString(36).slice(2, 8) + Math.random().toString(36).slice(2, 6);
        document.getElementById('eu-new-password').value = random;
      });
      document.getElementById('eu-save').addEventListener('click', async function() {
        const u = data.users.find(function(x) { return x.id === editingUserId; });
        if (!u) return;
        u.display_name = document.getElementById('eu-name').value.trim() || u.display_name;
        u.phone = document.getElementById('eu-phone').value.trim() || u.phone;
        u.email = document.getElementById('eu-email').value.trim() || u.email;
        u.role = document.getElementById('eu-role').value;
        u.disabled = document.getElementById('eu-disabled').checked;
        const newPw = document.getElementById('eu-new-password').value;
        if (newPw) {
          u.password_hash = await s.sha256(newPw);
          s.toast('Password reset for ' + u.username);
        } else {
          s.toast('Saved changes');
        }
        document.getElementById('edit-user-modal').classList.remove('show');
        editingUserId = null;
        renderUsers();
      });
      document.getElementById('eu-delete').addEventListener('click', function() {
        const u = data.users.find(function(x) { return x.id === editingUserId; });
        if (!u) return;
        if (u.id === t.user_id) { s.toast('You cannot delete yourself'); return; }
        if (!confirm('Delete user ' + u.username + ' (' + u.display_name + ')? Their shifts will remain in data.json but they will be unassigned.')) return;
        data.users = data.users.filter(function(x) { return x.id !== editingUserId; });
        document.getElementById('edit-user-modal').classList.remove('show');
        editingUserId = null;
        s.toast('User deleted');
        renderUsers();
      });

      const toList = document.getElementById('timeoff-list');
      if (data.time_off.length === 0) {
        toList.innerHTML = '<p class="empty">No requests.</p>';
      } else {
        toList.innerHTML = data.time_off.map(function(it) {
          return '<div class="list-item"><div><div class="who">' + s.getUserName(data, it.user_id) + '</div><div class="meta">' + s.formatDate(it.start_date, {short:true}) + ' – ' + s.formatDate(it.end_date, {short:true}) + ' · ' + (it.reason || '—') + '</div></div><span class="badge badge-' + it.status + '">' + it.status + '</span></div>';
        }).join('');
      }

      renderApprovals();
    })();
  </script>
</AppLayout>
