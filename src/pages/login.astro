---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="theme-color" content="#dc2626" />
  <title>&amp;Shawarma — Login</title>
  <script is:inline src="/AndShawarma/app.js?v=20260706104657"></script>
  <script is:inline>
    // Clear any stale token + pending so login always requires fresh input.
    try { localStorage.removeItem('shawarma.pending'); } catch (e) {}
  </script>
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <div class="login-header">
        <img src="/AndShawarma/logo.jpg" alt="&Shawarma" style="height:5rem;width:auto;margin:0 auto 0.75rem;display:block;background:#fff;padding:0.5rem;border-radius:0.75rem;" />
        <h1 class="login-title">Staff Login</h1>
        <p class="login-sub">Sign in to view your schedule</p>
      </div>

      <div class="error" id="error"></div>

      <form id="login-form">
        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" class="input" autocomplete="username" required />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" class="input" autocomplete="current-password" required />
        </div>
        <button type="submit" class="btn-primary btn-block">Sign in</button>
      </form>

      <div style="text-align:right;margin-top:0.5rem;">
        <a href="#" id="forgot-link" style="font-size:0.75rem;color:var(--color-muted);">Forgot password?</a>
      </div>

      <!-- Forgot password modal -->
      <div class="modal-backdrop" id="forgot-modal">
        <div class="modal">
          <div class="modal-header">
            <h2>Reset password</h2>
            <button class="modal-close" id="forgot-close">×</button>
          </div>
          <div class="modal-body">
            <p style="color:var(--color-muted);font-size:0.875rem;margin:0 0 0.75rem;">Enter your username. If an admin email is on file, a reset link will be sent there.</p>
            <div class="field"><label>Username</label><input type="text" id="forgot-username" class="input" placeholder="your username" /></div>
            <div id="forgot-result" style="margin-top:0.5rem;display:none;"></div>
          </div>
          <div class="modal-footer">
            <button class="btn-primary" id="forgot-send">Send reset link</button>
          </div>
        </div>
      </div>

      <div class="demo-creds">
        <strong>Demo accounts (tap to fill):</strong>
        <div class="demo-grid" id="demo-grid"></div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      const s = window.shawarma;
      // Prefill from query string (?u=username&p=password)
      const params = new URLSearchParams(window.location.search);
      const preUser = params.get('u');
      const prePass = params.get('p');
      if (preUser) document.getElementById('username').value = preUser;
      if (prePass) document.getElementById('password').value = prePass;

      // Demo account grid (tap to fill the form)
      const demoCreds = [
        { username: 'ray',    password: 'ray2026admin', name: 'Ray Ally',     role: 'admin' },
        { username: 'azmeer', password: 'admin',        name: 'Azmeer',       role: 'admin' },
        { username: 'badar',  password: 'admin',        name: 'Badar Khokar', role: 'admin' },
        { username: 'jorge',  password: 'staff2026',    name: 'Jorge',        role: 'staff' },
        { username: 'jeremy', password: 'staff2026',    name: 'Jeremy',       role: 'staff' },
        { username: 'adnan',  password: 'staff2026',    name: 'Adnan',        role: 'staff' },
        { username: 'david',  password: 'staff2026',    name: 'David',        role: 'staff' },
        { username: 'albero', password: 'staff2026',    name: 'Albero',       role: 'staff' },
        { username: 'john',   password: 'staff2026',    name: 'John',         role: 'staff' },
        { username: 'sanaa',  password: 'staff2026',    name: 'Sanaa',        role: 'staff' },
        { username: 'bhanu',  password: 'staff2026',    name: 'Bhanu',        role: 'staff' },
      ];
      document.getElementById('demo-grid').innerHTML = demoCreds.map(function(d) {
        return '<button type="button" class="demo-pill" data-user="' + d.username + '" data-pass="' + d.password + '">' +
          '<span class="badge badge-' + d.role + '">' + d.role + '</span>' +
          '<span class="demo-name">' + d.name + '</span>' +
          '<code class="demo-cred">' + d.username + ' / ' + d.password + '</code>' +
        '</button>';
      }).join('');
      document.querySelectorAll('.demo-pill').forEach(function(p) {
        p.addEventListener('click', function() {
          document.getElementById('username').value = p.getAttribute('data-user');
          document.getElementById('password').value = p.getAttribute('data-pass');
          document.getElementById('username').focus();
        });
      });

      // Forgot password modal
      document.getElementById('forgot-link').addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('forgot-username').value = document.getElementById('username').value.trim();
        document.getElementById('forgot-result').style.display = 'none';
        document.getElementById('forgot-modal').classList.add('show');
        document.getElementById('forgot-username').focus();
      });
      document.getElementById('forgot-close').addEventListener('click', function() {
        document.getElementById('forgot-modal').classList.remove('show');
      });
      document.getElementById('forgot-send').addEventListener('click', async function() {
        const username = document.getElementById('forgot-username').value.trim();
        const result = document.getElementById('forgot-result');
        if (!username) { result.style.display = 'block'; result.innerHTML = '<div class="error show">Enter a username first.</div>'; return; }
        const data = await s.loadData();
        const u = data.users.find(function(x) { return x.username === username; });
        result.style.display = 'block';
        if (!u) {
          // Don't reveal whether the user exists — security best practice
          result.innerHTML = '<div class="error show" style="background:#dcfce7;color:#166534;">If that username exists, a reset link has been sent to the email on file. Check your inbox.</div>';
          setTimeout(function() { document.getElementById('forgot-modal').classList.remove('show'); }, 2000);
          return;
        }
        // Log the "email" to console (mock — real send via /api/notify)
        console.log('[PASSWORD RESET] To:', u.email, '| User:', u.username, '| Reset link: https://therayally-create.github.io/AndShawarma/reset?u=' + encodeURIComponent(u.username) + '&t=' + Date.now());
        // For real deployment: fetch('/api/reset-password', { method: 'POST', body: JSON.stringify({ username: u.username, email: u.email }) })
        result.innerHTML = '<div class="error show" style="background:#dcfce7;color:#166534;">✅ If that username exists, a reset link has been sent to <strong>' + u.email + '</strong>. Check your inbox.</div>';
        s.toast('Reset link sent');
        setTimeout(function() { document.getElementById('forgot-modal').classList.remove('show'); }, 3000);
      });

      if (s.getToken()) {
        window.location.href = s.baseUrl('/schedule');
        return;
      }
      const form = document.getElementById('login-form');
      const errorEl = document.getElementById('error');
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        errorEl.classList.remove('show');
        const username = document.getElementById('username').value.trim();
        const password = document.getElementById('password').value;
        const btn = form.querySelector('button');
        btn.disabled = true;
        btn.textContent = 'Signing in...';
        let result;
        try {
          const data = await s.loadData();
          result = await s.login(username, password, data.users);
        } catch (err) {
          result = { ok: false, error: 'Network error: ' + err.message };
        }
        btn.disabled = false;
        btn.textContent = 'Sign in';
        if (!result.ok) {
          errorEl.textContent = result.error;
          errorEl.classList.add('show');
          return;
        }
        window.location.href = s.baseUrl('/schedule');
      });
    })();
  </script>
</body>
</html>
