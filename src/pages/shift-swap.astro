---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Shift Swap" active="swap">
  <div class="card">
    <h2>🔄 My Upcoming Shifts</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">Tap a shift to request a swap with another staff member.</p>
    <div id="my-shifts"><p class="empty">Loading...</p></div>
  </div>

  <div class="card">
    <h2>👥 Team — see who you're swapping with</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">All crew members and their next shift. Tap "Request swap" on a shift above, then enter the username.</p>
    <div class="roster-grid" id="roster-grid"><p class="empty">Loading...</p></div>
  </div>

  <div class="card">
    <h2>📋 Swap Requests</h2>
    <div id="swap-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();
      const today = s.todayISO();
      const myShifts = s.getShiftsForUser(data, t.user_id).filter(function(x) { return x.date >= today; });
      const list = document.getElementById('my-shifts');
      if (myShifts.length === 0) {
        list.innerHTML = '<p class="empty">No upcoming shifts.</p>';
      } else {
        list.innerHTML = myShifts.map(function(sh) {
          return '<div class="list-item"><div><div class="who">' + s.formatDate(sh.date, {short:true}) + '</div><div class="meta">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + ' · ' + sh.role + '</div></div><button class="btn-secondary" data-swap="' + sh.id + '">Request swap</button></div>';
        }).join('');
        list.querySelectorAll('[data-swap]').forEach(function(b) {
          b.addEventListener('click', function() {
            const shiftId = b.getAttribute('data-swap');
            const target = prompt('Swap with which staff? Enter their username (staff1–staff8 or azmeer):');
            if (!target) return;
            const targetUser = data.users.find(function(u) { return u.username === target.trim(); });
            if (!targetUser) { s.toast('User not found: ' + target); return; }
            s.addPending({
              kind: 'shift_swap',
              requester_id: t.user_id,
              requester_name: t.display_name,
              target_user_id: targetUser.id,
              target_user_name: targetUser.display_name,
              shift_id: shiftId,
            });
            s.toast('Swap requested — admin notified');
            renderSwaps();
          });
        });
      }

      // Team roster
      const sorted = data.users.slice().sort(function(a, b) {
        if (a.role === 'admin' && b.role !== 'admin') return -1;
        if (b.role === 'admin' && a.role !== 'admin') return 1;
        if (a.role === 'manager' && b.role !== 'manager') return -1;
        if (b.role === 'manager' && a.role !== 'manager') return 1;
        return a.display_name.localeCompare(b.display_name);
      });
      document.getElementById('roster-grid').innerHTML = sorted.map(function(u) {
        const next = s.getShiftsForUser(data, u.id).filter(function(x) { return x.date >= today; })[0];
        const roleClass = u.role === 'admin' ? 'role-admin' : u.role === 'manager' ? 'role-manager' : 'role-staff';
        const nextHTML = next
          ? '<div class="roster-card-next">' + s.formatDate(next.date, {short: true}) + ' · ' + s.formatTime12(next.start) + '–' + s.formatTime12(next.end) + ' <span class="roster-card-next-role ' + next.role.toLowerCase() + '">' + next.role + '</span></div>'
          : '<div class="roster-card-next off">No upcoming shifts</div>';
        return '<div class="roster-card">' +
          '<div class="roster-card-head">' +
            '<div class="roster-card-name">' + u.display_name + '</div>' +
            '<span class="roster-card-role ' + roleClass + '">' + u.role + '</span>' +
          '</div>' +
          nextHTML +
        '</div>';
      }).join('');

      function renderSwaps() {
        const seedSwaps = s.getSwapsForUser(data, t.user_id);
        const myPending = s.getPending().filter(function(p) {
          return p.kind === 'shift_swap' &&
            (p.requester_id === t.user_id || p.target_user_id === t.user_id) &&
            p.status === 'pending';
        });
        const swapList = document.getElementById('swap-list');
        if (seedSwaps.length === 0 && myPending.length === 0) {
          swapList.innerHTML = '<p class="empty">No swap requests.</p>';
        } else {
          let html = '';
          myPending.forEach(function(sw) {
            const role = sw.requester_id === t.user_id ? 'You →' : 'You ←';
            const other = sw.requester_id === t.user_id ? sw.target_user_name : sw.requester_name;
            const shift = data.shifts.find(function(x) { return x.id === sw.shift_id; });
            const shiftDate = shift ? s.formatDate(shift.date, {short:true}) : '—';
            html += '<div class="list-item"><div><div class="who">' + role + ' ' + other + '</div><div class="meta">Shift on ' + shiftDate + '</div></div><span class="badge badge-pending">pending</span></div>';
          });
          seedSwaps.forEach(function(sw) {
            const role = sw.requester_id === t.user_id ? 'You →' : 'You ←';
            const other = sw.requester_id === t.user_id ? s.getUserName(data, sw.target_user_id) : s.getUserName(data, sw.requester_id);
            const shift = data.shifts.find(function(x) { return x.id === sw.shift_id; });
            const shiftDate = shift ? s.formatDate(shift.date, {short:true}) : '—';
            html += '<div class="list-item"><div><div class="who">' + role + ' ' + other + '</div><div class="meta">Shift on ' + shiftDate + '</div></div><span class="badge badge-' + sw.status + '">' + sw.status + '</span></div>';
          });
          swapList.innerHTML = html;
        }
      }
      renderSwaps();
    })();
  </script>
</AppLayout>
