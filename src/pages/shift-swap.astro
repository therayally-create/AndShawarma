---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Shift Swap" active="swap">
  <div class="card">
    <h2>📋 My Upcoming Shifts</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">Tap a shift to post it for swap — or post a custom hour block (e.g. "I need to leave at 3pm for an appointment"). Admin/manager must approve before anyone can take it.</p>
    <div id="my-shifts"><p class="empty">Loading...</p></div>
  </div>

  <div class="card" id="custom-post-card">
    <h2>✏️ Post custom hours for swap</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">Need someone to cover just part of a shift? Tell us which date, what time you need covered, and a reason.</p>
    <form id="custom-form">
      <div class="field">
        <label for="cp-date">Date</label>
        <input type="date" id="cp-date" class="input" required />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
        <div class="field">
          <label for="cp-start">Start time</label>
          <input type="time" id="cp-start" class="input" required />
        </div>
        <div class="field">
          <label for="cp-end">End time</label>
          <input type="time" id="cp-end" class="input" required />
        </div>
      </div>
      <div class="field">
        <label for="cp-reason">Reason</label>
        <input type="text" id="cp-reason" class="input" placeholder="e.g. Doctor appointment, family event" required />
      </div>
      <button type="submit" class="btn-primary">Post for swap</button>
    </form>
  </div>

  <div class="card">
    <h2>📢 Shifts available to take</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">Shifts other staff have posted as available. Tap "Take this" to request taking it (admin/manager must approve).</p>
    <div id="available-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card">
    <h2>📋 My Swap Activity</h2>
    <div id="swap-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();
      const today = s.todayISO();
      const myShifts = s.getShiftsForUser(data, t.user_id).filter(function(x) { return x.date >= today; });

      // Render my shifts as cards with "Post" + "Post custom" buttons
      const list = document.getElementById('my-shifts');
      if (myShifts.length === 0) {
        list.innerHTML = '<p class="empty">No upcoming shifts.</p>';
      } else {
        list.innerHTML = myShifts.map(function(sh) {
          return '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;">' +
            '<div style="flex:1;min-width:0;">' +
              '<div class="who">' + s.formatDate(sh.date, {short: true}) + '</div>' +
              '<div class="meta">' + s.formatTime12(sh.start) + ' – ' + s.formatTime12(sh.end) + ' · ' + sh.role + '</div>' +
            '</div>' +
            '<div style="display:flex;flex-direction:column;gap:0.25rem;align-items:flex-end;">' +
              '<button class="btn-secondary" data-post-shift="' + sh.id + '">Post for swap</button>' +
            '</div>' +
          '</div>';
        }).join('');
        list.querySelectorAll('[data-post-shift]').forEach(function(b) {
          b.addEventListener('click', function() {
            const shiftId = b.getAttribute('data-post-shift');
            const sh = data.shifts.find(function(x) { return x.id === shiftId; });
            if (!sh) return;
            s.addPending({
              kind: 'shift_post',
              shift_id: sh.id,
              requester_id: t.user_id,
              requester_name: t.display_name,
              post_type: 'full',
              date: sh.date,
              start: sh.start,
              end: sh.end,
              role: sh.role,
              reason: 'Posting entire shift for swap',
            });
            s.toast('Shift posted — admin will approve');
            renderAvailable();
            renderSwaps();
          });
        });
      }

      // Custom hours form
      document.getElementById('custom-form').addEventListener('submit', function(e) {
        e.preventDefault();
        const date = document.getElementById('cp-date').value;
        const start = document.getElementById('cp-start').value;
        const end = document.getElementById('cp-end').value;
        const reason = document.getElementById('cp-reason').value.trim();
        if (!date || !start || !end || !reason) return;
        if (end <= start) { s.toast('End must be after start'); return; }
        s.addPending({
          kind: 'shift_post',
          requester_id: t.user_id,
          requester_name: t.display_name,
          post_type: 'custom',
          date: date,
          start: start,
          end: end,
          role: 'FOH', // default; admin can edit
          reason: reason,
        });
        document.getElementById('custom-form').reset();
        s.toast('Custom hours posted — admin will approve');
        renderAvailable();
        renderSwaps();
      });

      // Available shifts to take (from localStorage approved posts)
      function renderAvailable() {
        const approved = s.getPending().filter(function(p) {
          return p.kind === 'shift_post' && p.status === 'approved' && p.requester_id !== t.user_id;
        });
        const list = document.getElementById('available-list');
        if (approved.length === 0) {
          list.innerHTML = '<p class="empty">No shifts posted right now.</p>';
          return;
        }
        list.innerHTML = approved.map(function(p) {
          return '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;">' +
            '<div style="flex:1;min-width:0;">' +
              '<div class="who">' + s.getUserName(data, p.requester_id) + '</div>' +
              '<div class="meta">' + s.formatDate(p.date, {short: true}) + ' · ' + s.formatTime12(p.start) + '–' + s.formatTime12(p.end) + ' · ' + p.role + '</div>' +
              '<div class="meta" style="font-style:italic;">' + (p.reason || '—') + '</div>' +
            '</div>' +
            '<div><button class="btn-primary" data-take="' + p.id + '">Take this</button></div>' +
          '</div>';
        }).join('');
        list.querySelectorAll('[data-take]').forEach(function(b) {
          b.addEventListener('click', function() {
            const postId = b.getAttribute('data-take');
            const post = approved.find(function(p) { return p.id === postId; });
            if (!post) return;
            s.addPending({
              kind: 'shift_take',
              post_id: postId,
              shift_id: post.shift_id,
              taker_id: t.user_id,
              taker_name: t.display_name,
              poster_id: post.requester_id,
              poster_name: post.requester_name,
              date: post.date,
              start: post.start,
              end: post.end,
              role: post.role,
              post_type: post.post_type,
              reason: post.reason,
            });
            s.toast('Take request submitted — admin will approve');
            renderSwaps();
          });
        });
      }

      // My swap activity: my posts + my take requests
      function renderSwaps() {
        const myPosts = s.getPending().filter(function(p) {
          return p.kind === 'shift_post' && p.requester_id === t.user_id;
        });
        const myTakes = s.getPending().filter(function(p) {
          return p.kind === 'shift_take' && p.taker_id === t.user_id;
        });
        const list = document.getElementById('swap-list');
        if (myPosts.length === 0 && myTakes.length === 0) {
          list.innerHTML = '<p class="empty">No swap activity yet.</p>';
          return;
        }
        let html = '';
        myPosts.forEach(function(p) {
          html += '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;">' +
            '<div style="flex:1;min-width:0;">' +
              '<div class="who">You posted: ' + s.formatDate(p.date, {short: true}) + ' · ' + s.formatTime12(p.start) + '–' + s.formatTime12(p.end) + '</div>' +
              '<div class="meta">' + (p.post_type === 'full' ? 'Full shift' : 'Custom hours') + ' · ' + (p.reason || '—') + '</div>' +
            '</div>' +
            '<span class="badge badge-' + p.status + '">' + p.status + '</span>' +
          '</div>';
        });
        myTakes.forEach(function(p) {
          html += '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;">' +
            '<div style="flex:1;min-width:0;">' +
              '<div class="who">You\'re taking: ' + s.formatDate(p.date, {short: true}) + ' · ' + s.formatTime12(p.start) + '–' + s.formatTime12(p.end) + '</div>' +
              '<div class="meta">From ' + (p.poster_name || '?') + ' · ' + (p.reason || '—') + '</div>' +
            '</div>' +
            '<span class="badge badge-' + p.status + '">' + p.status + '</span>' +
          '</div>';
        });
        list.innerHTML = html;
      }

      renderAvailable();
      renderSwaps();
    })();
  </script>
</AppLayout>
