---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Time Off" active="timeoff">
  <div class="card">
    <h2>🏖️ Request Time Off</h2>
    <form id="request-form">
      <div class="field">
        <label for="start_date">Start date</label>
        <input type="date" id="start_date" class="input" required />
      </div>
      <div class="field">
        <label for="end_date">End date</label>
        <input type="date" id="end_date" class="input" required />
      </div>
      <div class="field">
        <label for="reason">Reason</label>
        <input type="text" id="reason" class="input" placeholder="Vacation, appointment, etc." required />
      </div>
      <button type="submit" class="btn-primary">Submit request</button>
    </form>
  </div>

  <div class="card">
    <h2>📋 My Time-Off Requests</h2>
    <div id="my-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card" style="margin-top:1rem;">
    <h2>🏖️ Upcoming Time Off</h2>
    <p style="color:var(--color-muted);font-size:0.875rem;">All your approved time off on the schedule.</p>
    <div id="upcoming-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card" id="all-card">
    <h2>👥 All Time-Off Requests <span style="font-size:0.75rem;color:var(--color-muted);font-weight:400;">(manager / admin only)</span></h2>
    <div id="all-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();

      document.getElementById('request-form').addEventListener('submit', function(e) {
        e.preventDefault();
        s.addPending({
          kind: 'time_off',
          requester_id: t.user_id,
          requester_name: t.display_name,
          start_date: document.getElementById('start_date').value,
          end_date: document.getElementById('end_date').value,
          reason: document.getElementById('reason').value.trim(),
        });
        document.getElementById('request-form').reset();
        s.toast('Time-off submitted — admin must approve');
        renderAll();
      });

      function renderAll() {
        const myList = document.getElementById('my-list');
        const mine = s.getTimeOffForUser(data, t.user_id);
        // Combine data.json + my pending time-off requests
        const myPending = s.getPending().filter(function(p) {
          return p.kind === 'time_off' && p.requester_id === t.user_id && p.status === 'pending';
        });
        const myResolved = s.getPending().filter(function(p) {
          return p.kind === 'time_off' && p.requester_id === t.user_id && p.status !== 'pending';
        });
        if (mine.length === 0 && myPending.length === 0 && myResolved.length === 0) {
          myList.innerHTML = '<p class="empty">No requests yet.</p>';
        } else {
          let html = '';
          myPending.forEach(function(p) {
            html += '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;">' +
              '<div style="flex:1;min-width:0;">' +
                '<div class="who">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + '</div>' +
                '<div class="meta">' + (p.reason || '—') + '</div>' +
              '</div>' +
              '<div style="display:flex;gap:0.375rem;align-items:center;">' +
                '<span class="badge badge-pending">pending review</span>' +
                '<button class="btn-secondary" data-edit-to="' + p.id + '" style="padding:0.25rem 0.5rem;font-size:0.75rem;">Edit</button>' +
                '<button class="btn-secondary" data-cancel-to="' + p.id + '" style="padding:0.25rem 0.5rem;font-size:0.75rem;color:#991b1b;">Cancel</button>' +
              '</div>' +
            '</div>';
          });
          myResolved.forEach(function(p) {
            const denialHTML = p.status === 'denied' && p.denial_reason
              ? '<div class="meta" style="color:#991b1b;background:#fee2e2;padding:0.25rem 0.5rem;border-radius:0.25rem;margin-top:0.25rem;">Admin says: ' + p.denial_reason + '</div>'
              : '';
            html += '<div class="list-item"><div><div class="who">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + '</div><div class="meta">' + (p.reason || '—') + '</div>' + denialHTML + '</div><div style="display:flex;gap:0.375rem;align-items:center;"><span class="badge badge-' + p.status + '">' + p.status + '</span><button class="btn-secondary" data-cancel-to="' + p.id + '" style="padding:0.25rem 0.5rem;font-size:0.75rem;color:#991b1b;">Cancel</button></div></div>';
          });
          mine.forEach(function(it) {
            html += '<div class="list-item"><div><div class="who">' + s.formatDate(it.start_date, {short:true}) + ' – ' + s.formatDate(it.end_date, {short:true}) + '</div><div class="meta">' + (it.reason || '—') + '</div></div><span class="badge badge-' + it.status + '">' + it.status + '</span></div>';
          });
          myList.innerHTML = html;
        }

        if (t.role !== 'manager' && t.role !== 'admin') return;
        const card = document.getElementById('all-card');
        card.style.display = 'block';
        const allList = document.getElementById('all-list');
        const seeded = s.getAllTimeOff(data);
        const pending = s.getPending().filter(function(p) { return p.kind === 'time_off' && p.status === 'pending'; });
        if (seeded.length === 0 && pending.length === 0) {
          allList.innerHTML = '<p class="empty">No requests.</p>';
        } else {
          let html = '';
          pending.forEach(function(p) {
            html += '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;"><div style="flex:1;min-width:0;"><div class="who">' + s.getUserName(data, p.requester_id) + '</div><div class="meta">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + ' · ' + (p.reason || '—') + '</div></div><div style="display:flex;gap:0.5rem;align-items:center;"><span class="badge badge-pending">pending</span><button class="btn-primary" data-approve="' + p.id + '">Approve</button><button class="btn-secondary" data-deny="' + p.id + '">Deny</button></div></div>';
          });
          // Show seeded with status + re-classify buttons for pending
          seeded.forEach(function(it) {
            let actions = '<span class="badge badge-' + it.status + '">' + it.status + '</span>';
            if (it.status === 'pending') {
              actions += ' <button class="btn-primary" data-approve-seeded="' + it.id + '">Approve</button> <button class="btn-secondary" data-deny-seeded="' + it.id + '">Deny</button>';
            }
            html += '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;"><div style="flex:1;min-width:0;"><div class="who">' + s.getUserName(data, it.user_id) + '</div><div class="meta">' + s.formatDate(it.start_date, {short:true}) + ' – ' + s.formatDate(it.end_date, {short:true}) + ' · ' + (it.reason || '—') + '</div></div><div style="display:flex;gap:0.5rem;align-items:center;">' + actions + '</div></div>';
          });
          allList.innerHTML = html;
          allList.querySelectorAll('[data-approve]').forEach(function(b) {
            b.addEventListener('click', function() {
              s.resolvePending(b.getAttribute('data-approve'), 'approved');
              s.toast('Approved — shifts unassigned for those dates');
              // Clear data cache so the change reflects immediately
              window.__dataCache = null;
              renderAll();
            });
          });
          allList.querySelectorAll('[data-deny]').forEach(function(b) {
            b.addEventListener('click', function() {
              const id = b.getAttribute('data-deny');
              const reason = prompt('Why are you denying this time-off request? (shown to the staff member)');
              if (reason === null) return; // cancelled
              s.resolvePending(id, 'denied');
              // Attach denial reason by updating the pending entry
              const all = s.getPending();
              const entry = all.find(function(x) { return x.id === id; });
              if (entry) {
                entry.denial_reason = reason || 'No reason given';
                s.setPending(all);
              }
              s.toast('Denied — staff will see your reason');
              window.__dataCache = null;
              renderAll();
            });
          });
          // Approve seeded request — flags it approved + clears data cache so the
          // unassignment takes effect on the next page load
          allList.querySelectorAll('[data-approve-seeded]').forEach(function(b) {
            b.addEventListener('click', function() {
              const seedId = b.getAttribute('data-approve-seeded');
              const it = seeded.find(function(x) { return x.id === seedId; });
              if (!it) return;
              s.addPending({
                kind: 'time_off',
                requester_id: it.user_id,
                requester_name: s.getUserName(data, it.user_id),
                start_date: it.start_date,
                end_date: it.end_date,
                reason: it.reason,
              });
              s.toast('Approved — refreshing');
              window.__dataCache = null;
              renderAll();
            });
          });
          // Deny seeded — also goes through pending so the staff sees "denied"
          allList.querySelectorAll('[data-deny-seeded]').forEach(function(b) {
            b.addEventListener('click', function() {
              const seedId = b.getAttribute('data-deny-seeded');
              const it = seeded.find(function(x) { return x.id === seedId; });
              if (!it) return;
              const reason = prompt('Why are you denying this time-off request? (shown to the staff member)');
              if (reason === null) return;
              s.addPending({
                kind: 'time_off',
                requester_id: it.user_id,
                requester_name: s.getUserName(data, it.user_id),
                start_date: it.start_date,
                end_date: it.end_date,
                reason: it.reason,
                status: 'denied',
                denial_reason: reason || 'No reason given',
              });
              s.toast('Denied');
              window.__dataCache = null;
              renderAll();
            });
          });
        }
      }
      function renderUpcoming() {
        const list = document.getElementById('upcoming-list');
        // Approved time-off from localStorage (pending ones for this user, with status approved)
        const mine = s.getPending().filter(function(p) {
          return p.kind === 'time_off' && p.requester_id === t.user_id && p.status === 'approved' && p.start_date && p.end_date;
        });
        // Also from data.json time_off
        const seeded = s.getTimeOffForUser(data, t.user_id).filter(function(x) { return x.status === 'approved'; });
        // Merge
        const all = mine.concat(seeded).filter(function(x) { return x.end_date >= today; }).sort(function(a, b) { return a.start_date.localeCompare(b.start_date); });
        if (all.length === 0) {
          list.innerHTML = '<p class="empty">No upcoming time off scheduled.</p>';
          return;
        }
        list.innerHTML = all.map(function(it) {
          const days = daysBetween(it.start_date, it.end_date) + 1;
          return '<div class="list-item" style="align-items:flex-start;padding:0.75rem 0;">' +
            '<div style="flex:1;min-width:0;">' +
              '<div class="who">🏖️ ' + s.formatDate(it.start_date, {short: true}) + ' – ' + s.formatDate(it.end_date, {short: true}) + '</div>' +
              '<div class="meta">' + days + ' day' + (days === 1 ? '' : 's') + ' · ' + (it.reason || 'on leave') + '</div>' +
            '</div>' +
            '<span class="badge badge-approved">approved</span>' +
          '</div>';
        }).join('');
      }
      function daysBetween(startISO, endISO) {
        const s = new Date(startISO + 'T00:00:00');
        const e = new Date(endISO + 'T00:00:00');
        return Math.round((e - s) / 86400000);
      }

      // Wire edit + cancel buttons after each render
      function wireActions() {
        myList.querySelectorAll('[data-cancel-to]').forEach(function(b) {
          b.addEventListener('click', function() {
            const id = b.getAttribute('data-cancel-to');
            if (!confirm('Cancel this time-off request?')) return;
            const all = s.getPending().filter(function(x) { return x.id !== id; });
            s.setPending(all);
            s.toast('Request cancelled');
            window.__dataCache = null;
            renderAll();
            renderUpcoming();
          });
        });
        myList.querySelectorAll('[data-edit-to]').forEach(function(b) {
          b.addEventListener('click', function() {
            const id = b.getAttribute('data-edit-to');
            const all = s.getPending();
            const entry = all.find(function(x) { return x.id === id; });
            if (!entry) return;
            // Pre-fill the form with current values and remove the old entry
            document.getElementById('start_date').value = entry.start_date;
            document.getElementById('end_date').value = entry.end_date;
            document.getElementById('reason').value = entry.reason || '';
            // Remove the old pending entry
            s.setPending(all.filter(function(x) { return x.id !== id; }));
            s.toast('Edit the dates and submit again');
            window.__dataCache = null;
            renderAll();
            document.getElementById('reason').focus();
          });
        });
      }

      renderAll();
      renderUpcoming();
      wireActions();
    })();
  </script>
</AppLayout>
