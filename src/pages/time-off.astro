---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Time Off" active="timeoff">
  <div class="card">
    <h2>🏖️ Request Time Off</h2>
    <form id="request-form">
      <div class="field">
        <label for="start_date">Start date</label>
        <input type="date" id="start_date" class="input" required />
      </div>
      <div class="field">
        <label for="end_date">End date</label>
        <input type="date" id="end_date" class="input" required />
      </div>
      <div class="field">
        <label for="reason">Reason</label>
        <input type="text" id="reason" class="input" placeholder="Vacation, appointment, etc." required />
      </div>
      <button type="submit" class="btn-primary">Submit request</button>
    </form>
  </div>

  <div class="card">
    <h2>📋 My Time-Off Requests</h2>
    <div id="my-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card" id="all-card" style="display:none;">
    <h2>👥 All Time-Off Requests <span style="font-size:0.75rem;color:var(--color-muted);font-weight:400;">(manager / admin only)</span></h2>
    <div id="all-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();

      document.getElementById('request-form').addEventListener('submit', function(e) {
        e.preventDefault();
        s.toast('Coming soon — backend not connected in v1');
      });

      const myItems = s.getTimeOffForUser(data, t.user_id);
      const myList = document.getElementById('my-list');
      if (myItems.length === 0) {
        myList.innerHTML = '<p class="empty">No requests yet.</p>';
      } else {
        myList.innerHTML = myItems.map(function(it) {
          return '<div class="list-item"><div><div class="who">' + s.formatDate(it.start_date, {short: true}) + ' – ' + s.formatDate(it.end_date, {short: true}) + '</div><div class="meta">' + (it.reason || '—') + '</div></div><span class="badge badge-' + it.status + '">' + it.status + '</span></div>';
        }).join('');
      }

      if (t.role === 'manager' || t.role === 'admin') {
        const card = document.getElementById('all-card');
        card.style.display = 'block';
        const allList = document.getElementById('all-list');
        const items = s.getAllTimeOff(data);
        if (items.length === 0) {
          allList.innerHTML = '<p class="empty">No requests.</p>';
        } else {
          allList.innerHTML = items.map(function(it) {
            let actions = '';
            if (it.status === 'pending') {
              actions = '<button class="btn-secondary" data-approve="' + it.id + '">Approve</button> <button class="btn-secondary" data-deny="' + it.id + '">Deny</button>';
            }
            return '<div class="list-item"><div><div class="who">' + s.getUserName(data, it.user_id) + '</div><div class="meta">' + s.formatDate(it.start_date, {short: true}) + ' – ' + s.formatDate(it.end_date, {short: true}) + ' · ' + (it.reason || '—') + '</div></div><div style="display:flex;gap:0.5rem;align-items:center;"><span class="badge badge-' + it.status + '">' + it.status + '</span>' + actions + '</div></div>';
          }).join('');
          allList.querySelectorAll('[data-approve]').forEach(function(b) { b.addEventListener('click', function() { s.toast('Coming soon'); }); });
          allList.querySelectorAll('[data-deny]').forEach(function(b) { b.addEventListener('click', function() { s.toast('Coming soon'); }); });
        }
      }
    })();
  </script>
</AppLayout>
