---
import AppLayout from '../layouts/AppLayout.astro';
---
<AppLayout title="&Shawarma — Time Off" active="timeoff">
  <div class="card">
    <h2>🏖️ Request Time Off</h2>
    <form id="request-form">
      <div class="field">
        <label for="start_date">Start date</label>
        <input type="date" id="start_date" class="input" required />
      </div>
      <div class="field">
        <label for="end_date">End date</label>
        <input type="date" id="end_date" class="input" required />
      </div>
      <div class="field">
        <label for="reason">Reason</label>
        <input type="text" id="reason" class="input" placeholder="Vacation, appointment, etc." required />
      </div>
      <button type="submit" class="btn-primary">Submit request</button>
    </form>
  </div>

  <div class="card">
    <h2>📋 My Time-Off Requests</h2>
    <div id="my-list"><p class="empty">Loading...</p></div>
  </div>

  <div class="card" id="all-card" style="display:none;">
    <h2>👥 All Time-Off Requests <span style="font-size:0.75rem;color:var(--color-muted);font-weight:400;">(manager / admin only)</span></h2>
    <div id="all-list"><p class="empty">Loading...</p></div>
  </div>

  <script>
    (async function() {
      const s = window.shawarma;
      const t = s.requireAuth();
      if (!t) return;
      const data = await s.loadData();

      document.getElementById('request-form').addEventListener('submit', function(e) {
        e.preventDefault();
        s.addPending({
          kind: 'time_off',
          requester_id: t.user_id,
          requester_name: t.display_name,
          start_date: document.getElementById('start_date').value,
          end_date: document.getElementById('end_date').value,
          reason: document.getElementById('reason').value.trim(),
        });
        document.getElementById('request-form').reset();
        s.toast('Time-off requested — admin notified');
        renderAll();
      });

      function renderAll() {
        const myList = document.getElementById('my-list');
        const mine = s.getTimeOffForUser(data, t.user_id);
        // Combine data.json + my pending time-off requests
        const myPending = s.getPending().filter(function(p) {
          return p.kind === 'time_off' && p.requester_id === t.user_id && p.status === 'pending';
        });
        if (mine.length === 0 && myPending.length === 0) {
          myList.innerHTML = '<p class="empty">No requests yet.</p>';
        } else {
          let html = '';
          myPending.forEach(function(p) {
            html += '<div class="list-item"><div><div class="who">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + '</div><div class="meta">' + (p.reason || '—') + '</div></div><span class="badge badge-pending">pending review</span></div>';
          });
          mine.forEach(function(it) {
            html += '<div class="list-item"><div><div class="who">' + s.formatDate(it.start_date, {short:true}) + ' – ' + s.formatDate(it.end_date, {short:true}) + '</div><div class="meta">' + (it.reason || '—') + '</div></div><span class="badge badge-' + it.status + '">' + it.status + '</span></div>';
          });
          myList.innerHTML = html;
        }

        if (t.role !== 'manager' && t.role !== 'admin') return;
        const card = document.getElementById('all-card');
        card.style.display = 'block';
        const allList = document.getElementById('all-list');
        const seeded = s.getAllTimeOff(data);
        const pending = s.getPending().filter(function(p) { return p.kind === 'time_off' && p.status === 'pending'; });
        const denied = s.getPending().filter(function(p) { return p.kind === 'time_off' && p.status === 'denied'; });
        if (seeded.length === 0 && pending.length === 0 && denied.length === 0) {
          allList.innerHTML = '<p class="empty">No requests.</p>';
        } else {
          let html = '';
          pending.forEach(function(p) {
            html += '<div class="list-item"><div><div class="who">' + s.getUserName(data, p.requester_id) + '</div><div class="meta">' + s.formatDate(p.start_date, {short:true}) + ' – ' + s.formatDate(p.end_date, {short:true}) + ' · ' + (p.reason || '—') + '</div></div><div style="display:flex;gap:0.5rem;align-items:center;"><span class="badge badge-pending">pending</span><button class="btn-secondary" data-approve="' + p.id + '">Approve</button><button class="btn-secondary" data-deny="' + p.id + '">Deny</button></div></div>';
          });
          seeded.forEach(function(it) {
            html += '<div class="list-item"><div><div class="who">' + s.getUserName(data, it.user_id) + '</div><div class="meta">' + s.formatDate(it.start_date, {short:true}) + ' – ' + s.formatDate(it.end_date, {short:true}) + ' · ' + (it.reason || '—') + '</div></div><span class="badge badge-' + it.status + '">' + it.status + '</span></div>';
          });
          allList.innerHTML = html;
          allList.querySelectorAll('[data-approve]').forEach(function(b) { b.addEventListener('click', function() { s.resolvePending(b.getAttribute('data-approve'), 'approved'); s.toast('Approved'); renderAll(); }); });
          allList.querySelectorAll('[data-deny]').forEach(function(b) { b.addEventListener('click', function() { s.resolvePending(b.getAttribute('data-deny'), 'denied'); s.toast('Denied'); renderAll(); }); });
        }
      }
      renderAll();
    })();
  </script>
</AppLayout>
